engine biome(1.0)
language js

`Effect.$outer(Effect.$inner($args), $rest)` as $m where {
  $outer <: r"^(map|flatMap|andThen|tap|tapError|catch|catchTag|catchTags|catchCause|mapError|zip|zipRight|zipLeft)$",
  register_diagnostic(span=$m, message="Avoid nested Effect combinators (Effect ladder). Build context once, then use a single flat pipeline.", severity="warning")
}
