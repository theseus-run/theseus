engine biome(1.0)
language js

or {
  `"effect/ServiceMap"`,
  `'effect/ServiceMap'`
} as $m where {
  register_diagnostic(span=$m, message="Effect v4: `effect/ServiceMap` was removed. Import Context from `effect` instead: `import { Context } from \"effect\"`. Load skill: effect-services-layers.", severity="error")
}
