engine biome(1.0)
language js

or {
  `Layer.succeed($tag, $impl)`,
  `Layer.effect($tag, $impl)`,
  `Layer.scoped($tag, $impl)`
} as $m where {
  register_diagnostic(span=$m, message="Effect v4: Layer constructors have both curried and two-arg forms. Curried Layer.succeed(Tag)(impl) is preferred for consistency with partial application patterns. Load skill: effect-services-layers.", severity="warning")
}
