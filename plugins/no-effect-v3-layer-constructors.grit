engine biome(1.0)
language js

or {
  `Layer.succeed($tag, $impl)`,
  `Layer.effect($tag, $impl)`,
  `Layer.scoped($tag, $impl)`
} where {
  register_diagnostic(message="Effect v4: Layer constructors are curried. Use Layer.succeed(Tag)(impl) instead of Layer.succeed(Tag, impl).", severity="error")
}
