engine biome(1.0)
language js

`Effect.gen($fn)` as $outer where {
  $fn <: contains `$a ? $b : $c` as $ternary where {
    register_diagnostic(span=$ternary, message="Avoid ternary expressions inside Effect.gen. Use Match.value for branching or Effect.if for conditional Effects.", severity="warning")
  }
}
