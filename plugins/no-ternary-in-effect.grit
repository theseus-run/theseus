engine biome(1.0)
language js

`Effect.gen($fn)` as $outer where {
  $fn <: contains `yield* ($cond ? $onTrue : $onFalse)` as $ternary where {
    register_diagnostic(span=$ternary, message="Avoid ternaries that choose yielded Effects inside Effect.gen. Use Match.value for branching or Effect.if for conditional Effects.", severity="warning")
  }
}
