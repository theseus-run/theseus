engine biome(1.0)
language js

or {
  `ServiceMap.Service`,
  `ServiceMap.Tag`
} as $m where {
  register_diagnostic(span=$m, message="Effect v4 (beta.50): ServiceMap was removed. Use Context.Service (class-style: `class Foo extends Context.Service<Foo, Shape>()(\"Foo\") {}`) from `effect`.", severity="error")
}
