{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@theseus.run/jsx-md",
    "paths": {
      "@theseus.run/runtime": ["./src/index.ts"],
      "@theseus.run/runtime/*": ["./src/*"],
      "@theseus.run/core": ["../theseus-core/src/index.ts"],
      "@theseus.run/core/*": ["../theseus-core/src/*"],
      "@theseus.run/tools": ["../theseus-tools/src/index.ts"],
      "@theseus.run/tools/*": ["../theseus-tools/src/*"],
      "@theseus.run/jsx-md": ["../jsx-md/src/index.ts"],
      "@theseus.run/jsx-md/jsx-runtime": ["../jsx-md/src/jsx-runtime.ts"],
      "@theseus.run/jsx-md/jsx-dev-runtime": ["../jsx-md/src/jsx-dev-runtime.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "bin/**/*"]
}
