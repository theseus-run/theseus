{
  "name": "@theseus.run/jsx-md-beautiful-mermaid",
  "version": "0.2.1",
  "description": "Mermaid component for @theseus.run/jsx-md. Renders diagrams as ASCII art via beautiful-mermaid — for terminals, LLM prompts, and anywhere SVG doesn't go.",
  "type": "module",
  "author": "Roman Dubinin <romanonthego@gmail.com> (https://romanonthego.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theseus-run/theseus.git",
    "directory": "packages/jsx-md-beautiful-mermaid"
  },
  "bugs": {
    "url": "https://github.com/theseus-run/theseus/issues"
  },
  "homepage": "https://theseus.run",
  "keywords": [
    "jsx",
    "tsx",
    "markdown",
    "mermaid",
    "ascii",
    "llm",
    "agents",
    "diagrams",
    "beautiful-mermaid"
  ],
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build --target=node --sourcemap=linked --outdir=dist --external beautiful-mermaid --external @theseus.run/jsx-md src/index.ts",
    "test": "bun test",
    "typecheck": "tsc"
  },
  "files": [
    "src/index.ts",
    "src/mermaid.tsx",
    "dist"
  ],
  "sideEffects": false,
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "beautiful-mermaid": ">=1.0.0"
  },
  "peerDependencies": {
    "@theseus.run/jsx-md": ">=0.2.0"
  },
  "devDependencies": {
    "@theseus.run/jsx-md": "workspace:*",
    "@types/bun": "1.3.10",
    "typescript": "5.9.3"
  }
}
