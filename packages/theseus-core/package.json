{
  "name": "@theseus.run/core",
  "version": "0.0.1",
  "description": "Typed primitives for LLM agent systems — Tool, Dispatch, Agent, Capsule, Satellite",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theseus-run/theseus.git",
    "directory": "packages/theseus-core"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "tsconfig.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./Tool": "./src/Tool.ts",
    "./Dispatch": "./src/Dispatch.ts",
    "./Capsule": "./src/Capsule.ts",
    "./Mission": "./src/Mission.ts",
    "./Grunt": "./src/Grunt.ts",
    "./Agent": "./src/Agent.ts",
    "./AgentComm": "./src/AgentComm.ts",
    "./Bridge": "./src/Bridge.ts",
    "./Satellite": "./src/Satellite.ts",
    "./Rpc": "./src/rpc/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@theseus.run/jsx-md": "0.2.1",
    "effect": "catalog:effect"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
